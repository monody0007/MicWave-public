# ========================================
# Brainwave IME environment template
# Copy this file to .env and fill your real secrets locally.
# ========================================

# Required for OpenAI realtime path (default provider)
OPENAI_API_KEY=your_openai_api_key_here

# Optional: x.ai (Grok) provider
XAI_API_KEY=your_xai_api_key_here

# Optional: Gemini file transcription
GOOGLE_API_KEY=your_google_api_key_here

# Provider: openai or xai
REALTIME_PROVIDER=openai

# OpenAI realtime model/config
OPENAI_REALTIME_MODEL=gpt-realtime-mini-2025-12-15
OPENAI_REALTIME_MODALITIES=text
OPENAI_REALTIME_SESSION_TTL_SEC=60

# x.ai realtime model/config
XAI_REALTIME_VOICE=Ara
XAI_REALTIME_SAMPLE_RATE=24000
XAI_REALTIME_MODALITIES=text

# IME behavior
BRAINWAVE_COMPLETE_SOUND=Morse
BRAINWAVE_LATENCY_PRESET=fast
BRAINWAVE_UPLOAD_CHUNK_MS=120
BRAINWAVE_PYAUDIO_CHUNK_SIZE=2880
BRAINWAVE_KEEP_PROVIDER_SESSION=1
BRAINWAVE_PROVIDER_SESSION_MAX_TURNS=8
# Rotate reused provider session after max age (seconds); 0 disables age-based rotation.
BRAINWAVE_PROVIDER_SESSION_MAX_AGE_SEC=7200
# If idle for this long before the next hotkey, refresh local WS session first.
# Defaults to BRAINWAVE_PROVIDER_SESSION_MAX_AGE_SEC when unset.
# BRAINWAVE_IDLE_WS_RECONNECT_SEC=36000
# Retry budget for provider session init on cold start / transient handshake failures.
# BRAINWAVE_PROVIDER_INIT_MAX_ATTEMPTS=3
# BRAINWAVE_PROVIDER_INIT_RETRY_DELAY_SEC=0.5
# Max seconds to wait for provider response completion after stop_recording.
# Increase this if long dictation is frequently finalized early.
# BRAINWAVE_RESPONSE_FINALIZE_TIMEOUT_SEC=120
BRAINWAVE_INCLUDE_INSTRUCTIONS_EACH_RESPONSE=1
BRAINWAVE_RECENT_AUDIO_CACHE_ENABLED=1
BRAINWAVE_RECENT_AUDIO_CACHE_LIMIT=0
# BRAINWAVE_RECENT_AUDIO_CACHE_DIR=~/Library/Application Support/Brainwave IME/recent_audio
